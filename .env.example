# LLM engine for answer generation: codex | claude (local CLI) | gemini (cloud API)
LLM_ENGINE=codex

# Gemini API (used when LLM_ENGINE=gemini). Key from https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Qdrant connection. http(s) URL = server (docker compose); a local path
# (e.g. qdrant_storage) or ":memory:" = embedded mode, no Docker needed.
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=portfolio

# Local embedding model (fastembed, no API key). Multilingual by default.
EMBED_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2

# Retrieval / chunking
TOP_K=4
CHUNK_SIZE=900
CHUNK_OVERLAP=150
DATA_DIR=data
